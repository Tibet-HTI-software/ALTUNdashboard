# Altun Logistics Dashboard — environment variables
#
# Copy this file to `.env` and fill in real values.
# Vite exposes any variable starting with `VITE_` to the client at build time.

# Mode toggle. Switches the API layer between mock services and a real backend.
# Allowed values: mock | live
VITE_API_MODE=mock

# Free-form environment label used by logging and display.
# Allowed values: development | staging | production
VITE_APP_ENV=development

# ── Supabase ────────────────────────────────────────────────────────────────
# Find these in Supabase Studio → Project Settings → API.
# Keep the anon key only on the client; never commit a service_role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Future variables (do NOT fill in yet — placeholders for later phases) ────
#
# Email gateway (when wired up):
# VITE_EMAIL_GATEWAY_URL=
#
# AI assistant layer (when wired up):
# VITE_AI_GATEWAY_URL=
